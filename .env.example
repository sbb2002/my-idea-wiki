# Google Drive
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
DRIVE_NOTES_FOLDER_ID=your_folder_id_here
DRIVE_WIKI_FOLDER_ID=your_folder_id_here
DRIVE_PIC_FOLDER_ID=your_pic_folder_id_here   # wikis/pic/ 폴더 ID (setup_drive.py 출력값)

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_WEBHOOK_URL=https://your-render-app.onrender.com/webhook

# App
APP_ENV=development
SCHEDULE_CRON=0 9 * * 1
TELEGRAM_WEBHOOK_SECRET=your_secret_token_here   # 선택: Webhook 보안 토큰

# Google OAuth (서비스 계정 대신 사용 — 파일 신규 생성 가능)
# scripts/get_oauth_token.py 실행 후 발급된 값을 입력
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
